ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=publicpulse;Username=postgres;Password=postgres
Jwt__Issuer=PublicPulse
Jwt__Audience=PublicPulse
Jwt__SigningKey=replace-with-a-long-random-development-signing-key
Jwt__ExpiryMinutes=60
Cloudinary__Folder=public-pulse/reports
Cloudinary__UploadPreset=public-pulse-report-images
Cloudinary__MaxImagesPerReport=5
Mapbox__AccessToken=replace-with-mapbox-access-token
MAPBOX_ACCESS_TOKEN=
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3001
